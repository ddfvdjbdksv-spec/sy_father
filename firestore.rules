rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAppCollection(collectionId) {
      return collectionId in [
        'students', 'attendance', 'exams', 'scores', 'expenses',
        'handouts', 'studentHandouts', 'materials', 'quizzes',
        'rewards', 'payments', 'waQueue', 'groups', 'cycles',
        'absenceSessions', 'dailyTreasuryArchives', 'staff', 'shifts',
        'courseCodes', 'platformCourses', 'platformSubscriptions'
      ];
    }

    match /app_config/{docId} {
      allow read, write: if true;
    }

    match /{collectionId}/{docId} {
      allow read, write: if isAppCollection(collectionId);
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
